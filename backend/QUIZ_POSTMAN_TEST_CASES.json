{
  "info": {
    "name": "Quiz API Test Cases",
    "description": "Complete JSON test cases for Quiz API endpoints. Note: Before creating a quiz, you must first create a CourseContent with contentType 'Quiz' using the /api/course-contents endpoint. This file contains only quiz-specific endpoints (/api/quizzes).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Quiz with Questions",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"contentId\": 3,\n  \"title\": \"HTML Basics Quiz\",\n  \"maxScore\": 100.0,\n  \"questions\": [\n    {\n      \"questionText\": \"What does HTML stand for?\",\n      \"options\": [\n        \"HyperText Markup Language\",\n        \"High Tech Modern Language\",\n        \"Home Tool Markup Language\",\n        \"Hyperlink and Text Markup Language\"\n      ],\n      \"correctAnswer\": \"0\"\n    },\n    {\n      \"questionText\": \"Which tag is used for the largest heading?\",\n      \"options\": [\n        \"<h1>\",\n        \"<h6>\",\n        \"<head>\",\n        \"<header>\"\n      ],\n      \"correctAnswer\": \"0\"\n    },\n    {\n      \"questionText\": \"What is the correct HTML element for inserting a line break?\",\n      \"options\": [\n        \"<br>\",\n        \"<break>\",\n        \"<lb>\",\n        \"<line>\"\n      ],\n      \"correctAnswer\": \"0\"\n    },\n    {\n      \"questionText\": \"Which attribute is used to define inline styles?\",\n      \"options\": [\n        \"class\",\n        \"style\",\n        \"styles\",\n        \"font\"\n      ],\n      \"correctAnswer\": \"1\"\n    },\n    {\n      \"questionText\": \"What is the correct HTML for creating a hyperlink?\",\n      \"options\": [\n        \"<a url=\\\"http://example.com\\\">Example</a>\",\n        \"<a href=\\\"http://example.com\\\">Example</a>\",\n        \"<a>http://example.com</a>\",\n        \"<a name=\\\"http://example.com\\\">Example</a>\"\n      ],\n      \"correctAnswer\": \"1\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/quizzes",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "quizzes"]
        }
      }
    },
    {
      "name": "2. Get Quiz (Instructor View - With Answers)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/quizzes/1?includeCorrectAnswers=true",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "quizzes", "1"],
          "query": [
            {
              "key": "includeCorrectAnswers",
              "value": "true"
            }
          ]
        }
      }
    },
    {
